# Generate the client and model libraries with sane defaults.

default:
	# create backup
	rm -rf backup
	mkdir backup
	mv ../client backup
	mv ../models backup

	# unwrap allOf fields
	./unwrap_allof.sh

	# generate using go-swagger
	# note upgrading to >= v0.34.0 will require code changes
	go run github.com/go-swagger/go-swagger/cmd/swagger@v0.33.2\
		generate client \
		--default-scheme=https \
		-f swagger.unwrapped.json \
		-t ../

	# fixup go.mod
	go get -u ../...
	# fixed to cli version from v1.7.0
	# todo: update cli and go-sdk to use newer non-backward compat go-openapi
	# (go-openapi/runtime generated by sagger >= v0.34.0 )
	go get github.com/go-openapi/runtime@v0.31.0
	go mod tidy
	
	(cd .. && go build ./models/... ./client/...)

	# cleanup
	rm swagger.unwrapped.json
	rm -rf backup

